{
    "compilerOptions": {
        "target": "ES2020",
        "module": "esnext",
        "lib": ["ES2020", "DOM"],
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
